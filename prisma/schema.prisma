generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AroundTheClockGame {
  id          String   @id @default(uuid())
  hitPercent  Float
  dartsThrown Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

model SinglesTrainingGame {
  id        String   @id @default(uuid())
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model DoublesTrainingGame {
  id         String   @id @default(uuid())
  hitPercent Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}

model ScoreTrainingGame {
  id               String   @id @default(uuid())
  totalScore       Int
  highestScore     Int
  oneEightyCount   Int
  threeDartAverage Float
  oneDartAverage   Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
}

model MatchGame {
  id                   String   @id @default(uuid())
  hasWon               Boolean
  opponent             String
  threeDartAverage     Float
  firstNineDartAverage Float
  checkoutThrown       Int
  checkoutHits         Int
  highestFinish        Int
  highestScore         Int
  bestLeg              Int
  worstLeg             Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([createdAt])
}
